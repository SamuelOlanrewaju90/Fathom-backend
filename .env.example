# Copy this file to .env and fill in real values before running.
# Never commit your actual .env file to GitHub.

# Random long random string — used to sign login sessions (JWTs).
# Generate one at https://randomkeygen.com (use a "CodeIgniter Encryption Key")
JWT_SECRET=change_this_to_a_long_random_string

# A second random string — used to encrypt 2FA secrets in the database.
# Must be exactly 32 characters long.
ENCRYPTION_KEY=change_this_to_exactly_32_chars!

# The URL of your frontend, so the backend only accepts requests from it.
# Example: https://your-site.netlify.app
FRONTEND_URL=http://localhost:5500

# Port the server runs on (Render/most hosts set this automatically).
PORT=4000
